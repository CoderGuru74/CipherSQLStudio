# Backend Environment Variables
# Copy this file to .env and update with your values

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database Configuration (Read-Only User)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ciphersql_studio
DB_READONLY_USER=ciphersql_readonly
DB_READONLY_PASSWORD=readonly_password
DB_SSL=false

# MongoDB Configuration (for persisting assignments/user attempts)
MONGODB_URI=mongodb://localhost:27017/ciphersql_studio
MONGODB_DB_NAME=ciphersql_studio

# LLM Configuration for Hints
# Choose your LLM provider: gemini or openai
LLM_PROVIDER=gemini

# For Google Gemini
LLM_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-pro

# For OpenAI (alternative)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-3.5-turbo

# Security Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_MAX_AGE=86400000

# Redis Configuration (optional, for session storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
